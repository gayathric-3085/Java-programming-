class Test1 {
    void fun() {
        System.out.println("Inside parent class method");
    }
}

class Test2 extends Test1 {
    void fun() {
        System.out.println("Inside child class overridden method");
    }
}

public class Main {
    public static void main(String[] args) {
        Test2 t2 = new Test2();
        t2.fun();
    }
}
