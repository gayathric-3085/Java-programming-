public class Main {

     static String reverse(String s) {
         String rev = "";

         for(int i = s.length()-1; i >= 0; i--) {
                         rev = rev + s.charAt(i);
         }

         return rev;
     }

    public static void main(String[] args) {
        String s = "Java";

         System.out.println(reverse(s));
     }
 }
