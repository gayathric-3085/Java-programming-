class Customer {
    private int cID;
    private String cName;
    private long cNum;
    public Customer() {    //zero parameter constructor
        cID=1;
        cName="Nithiya";
        cNum=8778995478L;
    }
    public Customer(int cID, String cName, long cNum) {
        this();
        this.cID = cID;
        this.cName = cName;
        this.cNum = cNum;
    }
    public int getcID() {
        return cID;
    }
    public String getcName() {
        return cName;
    }
    public long getcNum() {
        return cNum;
    }

}
void main() {
    Customer c1 = new Customer();
    IO.println(c1.getcID());
    IO.println(c1.getcName());
    IO.println(c1.getcNum());

    Customer c = new Customer(1, "Rohit", 8778975389L);
    IO.println(c.getcID());
    IO.println(c.getcName());
    IO.println(c.getcNum());
}
